# Database Connection (Schema-per-tenant PostgreSQL)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/nusakerja_db

# Redis Connection (BullMQ & Rate Limiting)
REDIS_URL=redis://localhost:6379

# Authentication & Security
AUTH_SECRET=supersecret_change_me_in_production_min_32_chars
AUTH_URL=http://localhost:3000

# App Configuration
NODE_ENV=development
APP_NAME=NusaKerja
APP_URL=http://localhost:3000

# S3 File Storage (S3-compatible bucket)
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=nusakerja-uploads

# Email Service (Resend)
RESEND_API_KEY=re_123456789_your_key_here
EMAIL_FROM=NusaKerja <noreply@nusakerja.id>

# Observability & Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_123456789
